{
  "name": "robys-coffee-house",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "verify:menu-content": "node scripts/verify-menu-content.mjs",
    "verify:instagram-tools": "node scripts/verify-instagram-tools.mjs",
    "verify:hits-feed": "node scripts/verify-hits-feed.mjs",
    "verify:regression": "node scripts/verify-regression-contracts.mjs && npm run verify:menu-content && npm run verify:instagram-tools && npm run verify:hits-feed && npm run verify:integrity && npm run verify:adversarial",
    "verify:performance": "node scripts/verify-performance-contract.mjs",
    "verify:live:smoke": "node scripts/live-smoke.mjs",
    "verify:security": "node scripts/verify-security-contracts.mjs && node scripts/scan-secrets.mjs",
    "verify:adversarial": "node scripts/verify-adversarial-contracts.mjs",
    "integrity:generate": "node scripts/generate-integrity-manifest.mjs",
    "verify:integrity": "node scripts/generate-integrity-manifest.mjs --check && node scripts/verify-integrity-manifest.mjs",
    "verify:integrity:live": "node scripts/verify-live-integrity.mjs",
    "security:audit": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm run build && node --check app.js && npm run verify:regression",
    "verify:bundle": "npm run check && git diff --exit-code -- app.js index.html && node scripts/verify-bundle.mjs",
    "verify:media": "node scripts/verify-media.mjs",
    "verify:deploy:live": "node scripts/verify-live-deploy.mjs",
    "audit:deps": "node scripts/audit-dependencies.mjs",
    "lighthouse:smoke": "npx --yes @lhci/cli@0.15.1 collect --config=lighthouse/lighthouserc.refresh-smoke.cjs",
    "lighthouse:collect:mobile": "npx --yes @lhci/cli@0.15.1 collect --config=lighthouse/lighthouserc.mobile.cjs",
    "lighthouse:collect:desktop": "npx --yes @lhci/cli@0.15.1 collect --config=lighthouse/lighthouserc.desktop.cjs"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "typescript": "5.8.3"
  }
}
