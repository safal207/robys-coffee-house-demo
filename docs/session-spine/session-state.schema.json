{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/safal207/robys-coffee-house-demo/docs/session-spine/session-state.schema.json",
  "title": "Agent Session Spine Structural State",
  "description": "Structural envelope for Session Spine state. Cross-field trust and merge-authorization invariants are enforced by scripts/session-state-lib.mjs and must be checked before acting on a state.",
  "$comment": "Schema-only validation is not merge authorization. Standard JSON Schema cannot require verified_for_sha to equal head_sha or require passed evidence whose sha equals head_sha, so validateSessionState() in scripts/session-state-lib.mjs is the semantic authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "sequence",
    "goal",
    "repository",
    "pull_request",
    "head_sha",
    "status",
    "completed",
    "blockers",
    "next_safe_action",
    "evidence",
    "verified_for_sha",
    "merge_authorized",
    "updated_at"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schema_version": { "const": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$" },
    "pull_request": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "previous_head_sha": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "status": {
      "enum": [
        "PLANNED",
        "IN_PROGRESS",
        "BLOCKED",
        "WAITING_FOR_CURRENT_HEAD_CHECKS",
        "READY_FOR_REVIEW",
        "AUTHORIZED",
        "DONE"
      ]
    },
    "completed": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "blockers": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_safe_action": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "ref", "sha", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "ref": { "type": "string", "minLength": 1 },
          "sha": {
            "oneOf": [
              { "type": "string", "pattern": "^[0-9a-f]{40}$" },
              { "type": "null" }
            ]
          },
          "status": { "enum": ["observed", "passed", "failed", "stale"] }
        }
      }
    },
    "verified_for_sha": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "merge_authorized": { "type": "boolean" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
