{
  "version": 1,
  "maxAttempts": 2,
  "minimumTouchTarget": 24,
  "recommendedTouchTarget": 40,
  "profiles": [
    { "id": "phone-320-short", "width": 320, "height": 568, "isMobile": true, "hasTouch": true },
    { "id": "phone-360", "width": 360, "height": 800, "isMobile": true, "hasTouch": true },
    { "id": "phone-390", "width": 390, "height": 844, "isMobile": true, "hasTouch": true },
    { "id": "phone-412", "width": 412, "height": 915, "isMobile": true, "hasTouch": true },
    { "id": "tablet-768", "width": 768, "height": 1024, "isMobile": true, "hasTouch": true },
    { "id": "tablet-landscape-1024", "width": 1024, "height": 768, "isMobile": true, "hasTouch": true },
    { "id": "laptop-1366", "width": 1366, "height": 768, "isMobile": false, "hasTouch": false },
    { "id": "desktop-1440", "width": 1440, "height": 1100, "isMobile": false, "hasTouch": false }
  ],
  "routes": [
    {
      "id": "landing",
      "path": "index.html",
      "ready": ".hero",
      "primarySelectors": [".hero .button", ".mobile-cta a", "#daily-offer a"]
    },
    {
      "id": "menu",
      "path": "menu.html",
      "ready": ".full-menu-item",
      "primarySelectors": ["#menu-share-button", ".menu-share-actions a", ".menu-page-cta-actions a", ".lang-button"]
    },
    {
      "id": "discover",
      "path": "discover.html",
      "ready": "#pairing-card",
      "primarySelectors": ["#next-pairing", "#mark-discovered", "#pairing-menu-link", ".lang-button"]
    }
  ]
}
