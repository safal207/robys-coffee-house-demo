        "backend": "not-built"
      },
      "requirements": [
        "REQ-PLATFORM-001-01 core routes work from cache after network failure",
        "REQ-PLATFORM-001-02 behavior-sensitive revisions change with assets",
        "REQ-PLATFORM-001-03 old caches are removed on activate"
      ],
      "stateModel": {
        "initial": "unsupported",
        "states": [
          "unsupported",
          "registering",
          "ready-online",
          "ready-offline",
          "registration-failed",
          "updating"
        ],
        "transitions": [
          "unsupported --supported--> registering",
          "registering --ready--> ready-online",
          "registering --error--> registration-failed",
          "ready-online --offline--> ready-offline",
          "ready-offline --online--> ready-online",
          "ready-online --update--> updating",
          "updating --activated--> ready-online"
        ]
      },
      "evidence": [
        "pwa.js#SERVICE_WORKER_URL",
        "pwa.js#offlineReady",
        "sw.js#CACHE_VERSION",
        "sw.js#navigationResponse"
      ],
      "tests": [
        "npm run verify:integrity",
        "npm run verify:live:smoke"
      ],
      "history": [
        [
          "2026-06-29",
          "released",
          "build:offline-20260629-7"
        ],
        [
          "2026-07-01",
          "released",
          "cache:robys-offline-v10-20260701-posters-10750cdfa32c-58d387ca0c01-96b566c9731e"
        ]
      ],
      "risks": [
        "Stale cache can preserve corrected defects",
        "Install fails if any core asset is missing"
      ],
      "nextGate": "Verify HTML query revisions against service-worker core assets.",
      "dependsOn": []
    },
    {
