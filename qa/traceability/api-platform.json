{
  "features": [
    {
      "id": "FEAT-API-001",
      "name": "Gazipaşa weather context",
      "domain": "external-context",
      "owner": "product-web",
      "current": {
        "lifecycle": "released",
        "operational": "fallback"
      },
      "layers": {
        "uiUx": "released",
        "api": "external",
        "backend": "not-built"
      },
      "requirements": [
        "REQ-API-001-01 network/payload failure preserves pairing with unavailable fallback",
        "REQ-API-001-02 late response cannot overwrite after user interaction",
        "REQ-API-001-03 fixed location/timezone and credentials omitted"
      ],
      "stateModel": {
        "initial": "idle",
        "states": [
          "idle",
          "loading",
          "hot",
          "rain",
          "cool",
          "mild",
          "unavailable",
          "ignored-after-interaction"
        ],
        "transitions": [
          "idle --loadWeather--> loading",
          "loading --temperature>=27--> hot",
          "loading --rain-or-code>=51--> rain",
          "loading --temperature<=17--> cool",
          "loading --finite-temperature--> mild",
          "loading --error--> unavailable",
          "loading --user-interacted--> ignored-after-interaction"
        ]
      },
      "evidence": [
        "discover.html#weather-context",
        "discover-v2.js#loadWeather",
        "external:https://api.open-meteo.com/v1/forecast"
      ],
      "tests": [
        "npm run verify:adversarial"
      ],
      "history": [
        [
          "2026-06-29",
          "released",
          "build:20260629-two-pairings-2"
        ]
      ],
      "risks": [
        "Third-party SLA/schema outside repository control",
        "No proxy cache/rate-limit telemetry"
      ],
      "nextGate": "Proxy only if weather becomes business-critical; preserve explicit fallback.",
      "dependsOn": []
    },
    {
      "id": "FEAT-PLATFORM-001",
      "name": "PWA registration, offline cache and navigation fallback",
      "domain": "platform",
      "owner": "platform-web",
      "current": {
        "lifecycle": "released",
        "operational": "fallback"
      },
      "layers": {
        "uiUx": "implemented",
