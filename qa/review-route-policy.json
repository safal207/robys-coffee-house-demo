{
  "contract": "RRM-ROUTE-001",
  "version": 1,
  "authority": "route-selection-only",
  "routeKeyVersion": 1,
  "depthOrder": ["L1", "L2", "L3", "L4"],
  "overridePolicy": {
    "enabled": true,
    "minimumReasonLength": 24,
    "requiredFields": [
      "routeId",
      "expectedHead",
      "expectedDepth",
      "approvedBy",
      "reason"
    ]
  },
  "nonNegotiablePolicy": {
    "automaticRouteByDepth": {
      "L1": "route-l1-standard",
      "L2": "route-l2-standard",
      "L3": "route-l3-standard",
      "L4": "route-l4-standard"
    },
    "minimumDistinctBindingActors": {
      "L1": 1,
      "L2": 1,
      "L3": 1,
      "L4": 1
    },
    "humanRequiredDepths": ["L1", "L2", "L3", "L4"],
    "advisoryActorsForbidden": true,
    "exactDepthMatchRequired": true
  },
  "routes": [
    {
      "id": "route-l1-standard",
      "depth": "L1",
      "priority": 400,
      "automatic": true,
      "governanceExceptionRequired": false,
      "label": "Low-risk maintainer review",
      "requiredActors": ["human-maintainer"],
      "stages": [
        { "id": "ci", "kind": "check", "actor": "system" },
        { "id": "draft-review", "kind": "review", "role": "draft_reviewer", "actor": "human-maintainer" }
      ]
    },
    {
      "id": "route-l2-standard",
      "depth": "L2",
      "priority": 400,
      "automatic": true,
      "governanceExceptionRequired": false,
      "label": "Product change maintainer review",
      "requiredActors": ["human-maintainer"],
      "stages": [
        { "id": "ci", "kind": "check", "actor": "system" },
        { "id": "mutations", "kind": "check", "actor": "system" },
        { "id": "evidence-review", "kind": "review", "role": "evidence_verifier", "actor": "human-maintainer" }
      ]
    },
    {
      "id": "route-l3-standard",
      "depth": "L3",
      "priority": 400,
      "automatic": true,
      "governanceExceptionRequired": false,
      "label": "Governance maintainer proof route",
      "requiredActors": ["human-maintainer"],
      "stages": [
        { "id": "trace-pdg", "kind": "check", "actor": "system" },
        { "id": "mutations", "kind": "check", "actor": "system" },
        { "id": "evidence-review", "kind": "review", "role": "evidence_verifier", "actor": "human-maintainer" },
        { "id": "proof-seal", "kind": "decision", "role": "operator", "actor": "human-maintainer" }
      ]
    },
    {
      "id": "route-l4-standard",
      "depth": "L4",
      "priority": 400,
      "automatic": true,
      "governanceExceptionRequired": false,
      "label": "Sensitive action human authorization route",
      "requiredActors": ["human-maintainer"],
      "stages": [
        { "id": "trace-pdg", "kind": "check", "actor": "system" },
        { "id": "security", "kind": "check", "actor": "system" },
        { "id": "mutations", "kind": "check", "actor": "system" },
        { "id": "evidence-review", "kind": "review", "role": "evidence_verifier", "actor": "human-maintainer" },
        { "id": "human-authorization", "kind": "decision", "role": "authorization_owner", "actor": "human-maintainer" },
        { "id": "action-gate", "kind": "gate", "actor": "system" }
      ]
    }
  ]
}
